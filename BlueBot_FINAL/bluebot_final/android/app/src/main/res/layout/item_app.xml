<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="56dp"
    android:orientation="vertical" android:paddingStart="16dp" android:paddingEnd="16dp"
    android:paddingTop="10dp" android:paddingBottom="10dp"
    android:background="?attr/selectableItemBackground">
    <TextView android:id="@+id/tv_nom_app" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:textColor="@color/blanc"
        android:textSize="13sp" android:textStyle="bold"/>
    <TextView android:id="@+id/tv_package" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:textColor="@color/gris" android:textSize="9sp"/>
</LinearLayout>
