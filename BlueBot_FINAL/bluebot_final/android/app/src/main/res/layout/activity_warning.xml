<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="#CC000000" android:gravity="center" android:orientation="vertical" android:padding="28dp">
    <ImageView android:layout_width="80dp" android:layout_height="80dp"
        android:src="@drawable/logo" android:layout_marginBottom="14dp" android:contentDescription="Logo"/>
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="BlueBot" android:textColor="@color/blanc" android:textSize="20sp" android:textStyle="bold"/>
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="FIRST Tech Challenge — Reims" android:textColor="@color/bleu_clair"
        android:textSize="11sp" android:layout_marginBottom="22dp"/>
    <androidx.cardview.widget.CardView android:layout_width="match_parent"
        android:layout_height="wrap_content" android:layout_marginBottom="20dp"
        app:cardBackgroundColor="#1A1A2E" app:cardCornerRadius="14dp">
        <TextView android:id="@+id/tv_message" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:padding="18dp"
            android:textColor="@color/blanc" android:textSize="14sp"
            android:lineSpacingMultiplier="1.4" android:gravity="center"/>
    </androidx.cardview.widget.CardView>
    <TextView android:id="@+id/tv_compteur" android:layout_width="72dp" android:layout_height="72dp"
        android:background="@drawable/circle_bg" android:gravity="center" android:text="10"
        android:textColor="@color/blanc" android:textSize="32sp" android:textStyle="bold"
        android:layout_marginBottom="10dp"/>
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="secondes avant fermeture" android:textColor="@color/gris"
        android:textSize="12sp" android:layout_marginBottom="22dp"/>
    <Button android:id="@+id/btn_retour" android:layout_width="match_parent"
        android:layout_height="48dp" android:text="🏠  Retour à l'accueil"
        android:textSize="14sp" android:backgroundTint="@color/bleu"/>
</LinearLayout>
